{
  "name": "TrainingCertificate",
  "type": "object",
  "properties": {
    "course_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "certificate_name": {
      "type": "string"
    },
    "issued_date": {
      "type": "string",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "format": "date"
    },
    "certificate_url": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "expiring_soon",
        "expired"
      ],
      "default": "active"
    }
  },
  "required": [
    "course_id",
    "user_id",
    "certificate_name"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}